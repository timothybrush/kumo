{
  "name": "@cloudflare/kumo-docs-astro",
  "version": "1.5.12",
  "private": true,
  "type": "module",
  "exports": {
    "./demo-metadata.json": "./dist/demo-metadata.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run codegen:demos && pnpm run generate-design-skill && astro build",
    "codegen:demos": "tsx scripts/extract-demo-examples.ts",
    "generate-design-skill": "node scripts/generate-design-skill.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "vitest run",
    "lint": "oxlint src/ && node ../../lint/lint-astro-colors.js src/",
    "lint:oxlint": "oxlint src/",
    "lint:astro": "node ../../lint/lint-astro-colors.js src/"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/sitemap": "^3.7.3",
    "@cloudflare/kumo": "workspace:*",
    "@phosphor-icons/react": "catalog:",
    "@tailwindcss/typography": "^0.5.19",
    "@types/turndown": "5.0.6",
    "astro": "7.1.1",
    "clsx": "catalog:",
    "echarts": "^6.0.0",
    "marked": "^18.0.6",
    "match-sorter": "^8.2.0",
    "motion": "^12.34.1",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "catalog:",
    "turndown": "7.2.2",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/mdast": "4.0.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "oxlint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.3.3",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
